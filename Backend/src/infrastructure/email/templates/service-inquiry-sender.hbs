<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>We received your service enquiry</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f8;font-family:Arial,Helvetica,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f4f4f8;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" cellspacing="0" cellpadding="0" style="width:100%;max-width:600px;background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <tr><td>{{> header}}</td></tr>
          <tr>
            <td style="padding:32px 40px;">
              <h2 style="color:#1a1a2e;font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:700;margin:0 0 16px;">
                Hi {{visitorName}},
              </h2>
              <p style="color:#333333;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.7;margin:0 0 20px;">
                Thank you for getting in touch about a service opportunity! I have received your enquiry and will review it carefully.
              </p>
              <div style="background-color:#f9f9fc;border-left:4px solid #e94560;padding:16px 20px;border-radius:0 4px 4px 0;margin:0 0 20px;">
                <p style="color:#666666;font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin:0 0 8px;">
                  Your enquiry summary
                </p>
                <p style="color:#333333;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.6;margin:0;">
                  {{messageSummary}}
                </p>
              </div>
              <p style="color:#555555;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;margin:0 0 20px;">
                I aim to respond to service enquiries within <strong>{{replySlaHours}} hours</strong>. I look forward to exploring how we might work together.
              </p>
              <p style="color:#555555;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;margin:0;">
                Warm regards,<br>
                <strong style="color:#1a1a2e;">{{ownerName}}</strong>
              </p>
            </td>
          </tr>
          <tr><td>{{> footer}}</td></tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
