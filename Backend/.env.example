# Environment Variables
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/portfolio

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Admin
# ADMIN_EMAIL is also used as the recipient for new contact message notifications (FR-010, FR-056)
ADMIN_EMAIL=admin@portfolio.dev
ADMIN_PASSWORD=Admin@12345

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (nodemailer — FR-051, FR-056)
# Supports any SMTP provider: Gmail, SendGrid SMTP relay, Brevo/Sendinblue, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Portfolio <no-reply@portfolio.dev>"

# Contact Email Notifications (FR-056)
# OWNER_NAME: displayed in outbound email templates as the portfolio owner's display name
OWNER_NAME=Your Name
# PORTFOLIO_URL: included in email footers and visitor confirmation emails
PORTFOLIO_URL=https://portfolio.dev
# ADMIN_PORTAL_URL: deep-link included in owner notification emails for quick inbox access
ADMIN_PORTAL_URL=https://admin.portfolio.dev
# REPLY_SLA_HOURS: expected response time shown in visitor confirmation emails (default: 48)
REPLY_SLA_HOURS=48
